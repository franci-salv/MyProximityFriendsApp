# Copy to `.env` for local dev. For production (Vercel: Settings → Environment Variables), set the
# same keys and redeploy — Vite inlines VITE_* at build time; changing env without redeploying leaves a broken bundle.

# Project URL from Supabase → Settings → API → Project URL
# Must include https:// and have no path (e.g. https://abcdefghijkl.supabase.co)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co

# Public client key from Supabase → Settings → API:
# - Legacy: "anon" / "public" JWT (three dot-separated segments), or
# - New: publishable key starting with sb_publishable_ (also valid with @supabase/supabase-js createClient)
# Do NOT use the service_role / secret key in the frontend.
VITE_SUPABASE_ANON_KEY=your-anon-or-publishable-key

# Optional. Where users land after clicking the magic link (must match Supabase Auth redirect allow-list).
# If unset, the app uses the current browser origin (fine for most single-origin deploys).
# Local: http://localhost:5173 (or whatever port Vite prints if 5173 is busy)
# Production: https://your-domain.com
VITE_APP_BASE_URL=http://localhost:5173
